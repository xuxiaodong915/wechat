/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* Loading */
.loading-container {
  padding: 40rpx;
}

.skeleton-card {
  height: 500rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.skeleton-title {
  height: 48rpx;
  width: 40%;
  margin-bottom: 16rpx;
}

.skeleton-tags {
  height: 36rpx;
  width: 60%;
}

/* Error */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
}

.retry-btn {
  background: #FF6B35;
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* Header */
.header {
  margin-bottom: 30rpx;
}

.date-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.subtitle-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* Card Area — clips off-screen cards */
.card-area {
  position: relative;
  overflow: hidden;
  margin-bottom: 20rpx;
  /* border-radius removed — let individual recipe-card provide it */
  /* This prevents 1px anti-aliasing bleed from adjacent cards */
}

/* Track — all cards laid out horizontally */
.card-track {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  touch-action: none;
  gap: 20rpx;
}

/* Each card slot occupies exactly the visible width (100% of container) */
.card-slot {
  flex: 0 0 100%;
  display: flex;
  align-items: stretch;
}

.recipe-card {
  width: 100%;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  border-radius: 24rpx;
}

.card-image {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #FFE0B2, #FFCC80);
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-image-fallback {
  height: 360rpx;
}

.image-emoji {
  font-size: 120rpx;
}

.card-body {
  padding: 24rpx;
}

.recipe-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.tags-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.ingredients-preview {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.ingredients-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Dot indicator */
.indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ddd;
  transition: all 0.3s;
}

.dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: #FF6B35;
}

/* Action buttons */
.actions {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 30rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-icon.favorited {
  animation: heartBeat 0.3s;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.action-label {
  font-size: 22rpx;
  color: #666;
}

/* Backup section */
.backup-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.backup-scroll {
  white-space: nowrap;
  padding-bottom: 16rpx;
}

.backup-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  margin-right: 20rpx;
  background: white;
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.backup-item:active {
  opacity: 0.7;
}

.backup-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FFF3E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.backup-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  display: block;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140rpx;
}

.backup-meta {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
