/* pages/shopping-list/shopping-list.wxss */
.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 20rpx;
}

/* Add bar */
.add-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.add-input {
  flex: 1;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.add-qty {
  width: 140rpx;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.add-btn {
  background: #FF6B35;
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  line-height: 1.8;
}

.add-btn[disabled] {
  opacity: 0.5;
}

/* List */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.clear-btn {
  font-size: 26rpx;
  color: #FF6B35;
}

.list {
  padding-bottom: 40rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.list-item.checked {
  opacity: 0.6;
}

.item-check {
  flex-shrink: 0;
}

.check-icon {
  font-size: 40rpx;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.item-name.done {
  text-decoration: line-through;
  color: #bbb;
}

.item-qty {
  font-size: 22rpx;
  color: #FF6B35;
  display: block;
}

.item-source {
  font-size: 20rpx;
  color: #bbb;
  display: block;
  margin-top: 4rpx;
}

.item-del {
  flex-shrink: 0;
  padding: 8rpx;
}

.del-icon {
  font-size: 32rpx;
}

/* Empty */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.go-btn {
  background: #FF6B35;
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* Loading */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
